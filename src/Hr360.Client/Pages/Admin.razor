@page "/admin"
@attribute [Authorize(Roles = "HRAdmin,SystemAdmin")]
@inject Hr360ApiClient Api
@inject ISnackbar Snackbar

<PageTitle>HR 360 Admin</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <div>
            <MudText Typo="Typo.h5">Admin workspace</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Templates, review cycles, assignments, and reporting.</MudText>
        </div>
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" OnClick="LoadAsync" StartIcon="@Icons.Material.Filled.Refresh">Refresh</MudButton>
    </MudStack>

    @if (loading)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (!string.IsNullOrWhiteSpace(error))
    {
        <MudAlert Severity="Severity.Error">@error</MudAlert>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.subtitle1">Templates</MudText>
                    <MudText Typo="Typo.h4">@templates.Count</MudText>
                    <MudButton Class="mt-3" FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateTemplateAsync" StartIcon="@Icons.Material.Filled.Add">
                        Create default
                    </MudButton>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.subtitle1">Employees</MudText>
                    <MudText Typo="Typo.h4">@employees.Count</MudText>
                    <MudButton Class="mt-3" FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" Disabled="@(templates.Count == 0 || employees.Count < 2)" OnClick="CreateCycleAsync" StartIcon="@Icons.Material.Filled.PlayArrow">
                        Start cycle
                    </MudButton>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.subtitle1">Completion</MudText>
                    <MudText Typo="Typo.h4">@(report?.CompletionRate ?? 0)%</MudText>
                    <MudText Typo="Typo.caption">@((report?.SubmittedAssignments ?? 0)) of @((report?.TotalAssignments ?? 0)) submitted</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-4" Outlined="true">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Cycles</MudText>
            <MudTable Items="cycles" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Window</MudTh>
                    <MudTh>Assignments</MudTh>
                    <MudTh>Submitted</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Name</MudTd>
                    <MudTd>@context.Status</MudTd>
                    <MudTd>@context.StartsOn to @context.EndsOn</MudTd>
                    <MudTd>@context.AssignmentCount</MudTd>
                    <MudTd>@context.SubmittedCount</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        <MudPaper Class="pa-4" Outlined="true">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Reporting</MudText>
            <MudTable Items="report?.Cycles ?? []" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Cycle</MudTh>
                    <MudTh>Completion</MudTh>
                    <MudTh>Suppression</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.CycleName</MudTd>
                    <MudTd>@context.CompletionRate%</MudTd>
                    <MudTd>@(context.IsSuppressed ? "Suppressed below anonymity threshold" : "Available")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        @if (report?.Cycles.SelectMany(c => c.Reviewees).Any() == true)
        {
            <MudPaper Class="pa-4" Outlined="true">
                <MudText Typo="Typo.subtitle1" Class="mb-2">Anonymized results</MudText>

                @foreach (var cycleReport in report.Cycles)
                {
                    if (cycleReport.Reviewees.Count == 0)
                    {
                        continue;
                    }

                    <MudText Typo="Typo.subtitle2" Class="mt-3">@cycleReport.CycleName</MudText>

                    @foreach (var reviewee in cycleReport.Reviewees)
                    {
                        <MudPaper Class="pa-3 my-2" Outlined="true">
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.body1">@reviewee.RevieweeName</MudText>
                                <MudSpacer />
                                <MudChip T="string" Size="Size.Small" Color="@(reviewee.IsSuppressed ? Color.Warning : Color.Success)">
                                    @reviewee.SubmittedCount submissions
                                </MudChip>
                            </MudStack>

                            @if (reviewee.IsSuppressed)
                            {
                                <MudAlert Class="mt-2" Severity="Severity.Warning">
                                    Results are suppressed until at least three reviewers have submitted feedback for this person.
                                </MudAlert>
                            }
                            else
                            {
                                @if (reviewee.RatingQuestions.Count > 0)
                                {
                                    <MudText Typo="Typo.caption" Class="mt-3">Ratings</MudText>
                                    <MudTable Items="reviewee.RatingQuestions" Dense="true">
                                        <HeaderContent>
                                            <MudTh>Question</MudTh>
                                            <MudTh>Average</MudTh>
                                            <MudTh>Range</MudTh>
                                            <MudTh>Responses</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>@context.Prompt</MudTd>
                                            <MudTd>@context.Average</MudTd>
                                            <MudTd>@context.Minimum - @context.Maximum</MudTd>
                                            <MudTd>@context.ResponseCount</MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }

                                @if (reviewee.YesNoQuestions.Count > 0)
                                {
                                    <MudText Typo="Typo.caption" Class="mt-3">Yes / no</MudText>
                                    <MudTable Items="reviewee.YesNoQuestions" Dense="true">
                                        <HeaderContent>
                                            <MudTh>Question</MudTh>
                                            <MudTh>Yes</MudTh>
                                            <MudTh>No</MudTh>
                                            <MudTh>Yes %</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd>@context.Prompt</MudTd>
                                            <MudTd>@context.YesCount</MudTd>
                                            <MudTd>@context.NoCount</MudTd>
                                            <MudTd>@context.YesPercentage%</MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }

                                @foreach (var textQuestion in reviewee.TextQuestions.Where(q => q.ResponseCount > 0))
                                {
                                    <MudText Typo="Typo.caption" Class="mt-3">@textQuestion.Prompt</MudText>
                                    <MudList T="string" Dense="true">
                                        @foreach (var comment in textQuestion.Comments)
                                        {
                                            <MudListItem T="string">@comment</MudListItem>
                                        }
                                    </MudList>
                                }
                            }
                        </MudPaper>
                    }
                }
            </MudPaper>
        }
    }
</MudStack>

@code {
    private List<EmployeeDto> employees = [];
    private List<ReviewTemplateDto> templates = [];
    private List<ReviewCycleDto> cycles = [];
    private ReportingSummaryDto? report;
    private bool loading;
    private string? error;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        loading = true;
        error = null;
        try
        {
            employees = (await Api.GetEmployeesAsync()).ToList();
            templates = (await Api.GetTemplatesAsync()).ToList();
            cycles = (await Api.GetCyclesAsync()).ToList();
            report = await Api.GetReportingSummaryAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task CreateTemplateAsync()
    {
        var request = new CreateTemplateRequest(
            $"Leadership feedback {DateTime.Now:HHmm}",
            "Reusable 360 template covering impact, collaboration, and growth.",
            new TemplateDefinitionDto([
                new TemplateSectionDto("impact", "Impact", [
                    new QuestionDto("impact-rating", "Rate this person's impact this cycle.", QuestionType.Rating, true, 1, 5, null),
                    new QuestionDto("impact-example", "Share one concrete example of impact.", QuestionType.FreeText, true, null, null, null)
                ]),
                new TemplateSectionDto("growth", "Growth", [
                    new QuestionDto("growth-text", "What should this person continue or improve?", QuestionType.FreeText, false, null, null, null),
                    new QuestionDto("recommend", "Would you recommend this person for broader responsibility?", QuestionType.YesNo, false, null, null, null)
                ])
            ]));

        await Api.CreateTemplateAsync(request);
        Snackbar.Add("Template created.", Severity.Success);
        await LoadAsync();
    }

    private async Task CreateCycleAsync()
    {
        var template = templates.First();
        var ids = employees.Select(e => e.Id).ToArray();
        var today = DateOnly.FromDateTime(DateTime.Today);
        var request = new CreateCycleRequest(
            $"360 cycle {DateTime.Now:MMM d}",
            template.Id,
            today.AddDays(-1),
            today.AddDays(21),
            ids,
            ids);

        await Api.CreateCycleAsync(request);
        Snackbar.Add("Review cycle started.", Severity.Success);
        await LoadAsync();
    }
}
