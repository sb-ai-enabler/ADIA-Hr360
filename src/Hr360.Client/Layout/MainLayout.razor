@inherits LayoutComponentBase
@inject NavigationManager Navigation

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudText Typo="Typo.h6">HR 360</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="me-3">@context.User.Identity?.Name</MudText>
                <MudButton Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Logout" OnClick="BeginSignOut">Sign out</MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Login" OnClick="BeginSignIn">Sign in</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer Open="true" Variant="DrawerVariant.Persistent" Elevation="0" ClipMode="DrawerClipMode.Always" Class="app-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="main-content">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private void BeginSignIn() => Navigation.NavigateToLogin("authentication/login");

    private void BeginSignOut() => Navigation.NavigateToLogout("authentication/logout");
}
